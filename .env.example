# Stitch MCP (Google) — request a fresh key; the previous one was exposed in git and must be rotated.
STITCH_API_KEY=

# ── Google OAuth ──────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── App Base URL ──────────────────────────────────────────
# Used by OAuth callback redirect. No trailing slash.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────
# @libsql/client — supports both local SQLite files and Turso cloud
#
# Local development (SQLite file):
DB_URL=file:./data/aether.db
#
# Vercel deployment (Turso):
# DB_URL=libsql://your-db-name.turso.io
# DB_AUTH_TOKEN=your-auth-token
